# Shared Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Web app
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Leave empty for same-origin API routing. Set this when the API is deployed separately.
VITE_API_BASE_URL=https://your-api-host.example.com

# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
CS2_CALLBACK_SHARED_SECRET=replace-with-strong-shared-secret
AUTO_APPROVE_KYC=true
DEPOSIT_ADDRESS_TRC20=TRC20-DEPOSIT-ADDRESS
DEPOSIT_ADDRESS_BEP20=BEP20-DEPOSIT-ADDRESS
