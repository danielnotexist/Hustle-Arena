# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=

# Railway backend configuration
# Use these only in Railway/backend environments, never in Vercel frontend variables.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3001
STEAM_OPENID_STATE_SECRET=
PORT=3001

# Platform hot wallet configuration
# Display-only frontend configuration. Real custody, sweeps, and signing must remain server-side.
VITE_PLATFORM_HOT_WALLET_ADDRESS=0xe9485f341b23d1d00a8a742a0ef1ad456a7ff3b6
VITE_PLATFORM_HOT_WALLET_NETWORK=BEP20
